-------------------------------------------------------------------------------
-- Regulated Cell Architecture (RCA) - Ada Variant
-- Control Plane
-------------------------------------------------------------------------------

package RCA.Control is

   ---------------------------------------------------------------------------
   -- (1) States
   ---------------------------------------------------------------------------

   -- Status: FREEZE
   type State is (Init, Idle, Running, Halt, Failure, Shutdown);

   ---------------------------------------------------------------------------
   -- (2) Modes
   ---------------------------------------------------------------------------

   -- Status: MUTABLE
   type Mode is (Mode_None, Debug);

   ---------------------------------------------------------------------------
   -- (3) Events
   ---------------------------------------------------------------------------

   -- Status: MUTABLE
   type Event is (Event_None);

   ---------------------------------------------------------------------------
   -- Control Plane
   ---------------------------------------------------------------------------

   -- Status: FREEZE
   type Control_Plane is record
      Current_State : State := Init;
      Current_Mode  : Mode  := Debug;
      Current_Event : Event := Event_None;
   end record;

end RCA.Control;
